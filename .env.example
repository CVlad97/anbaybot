# ==================================================
# ANBAYBOT / IKB COPYBOT — ENV TEMPLATE
# ==================================================
# Ne jamais commiter .env réel.
# Ne jamais mettre de secret dans le frontend.
# Les clés Binance avec retrait activé sont interdites pour ce projet.

# ==================================================
# Base de données
# ==================================================
DATABASE_URL="postgresql://user:password@host:5432/ikb_copybot"

# Supabase / Edge Functions
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# App
VITE_APP_BASE_URL="http://localhost:5173"
NEXT_PUBLIC_APP_BASE_URL="https://your-app.vercel.app"

# Sécurité cron
CRON_SECRET="generate-random-string"

# ==================================================
# Modes cockpit / trading
# ==================================================
# read_only | paper | spot_assisted | earn_assisted | futures_simulation | withdrawal_assisted
ACCOUNT_CONTROL_MODE="read_only"

# paper | live
TRADING_MODE="paper"

# Live doit rester false tant que les routes signées, order-test et validations ne sont pas prêtes.
ALLOW_LIVE_TRADING="false"
ALLOW_AUTONOMOUS_LIVE_TRADING="false"

# Produits autorisés — tout est false par défaut.
ALLOW_SPOT_TRADING="false"
ALLOW_FUTURES_TRADING="false"
ALLOW_MARGIN_TRADING="false"
ALLOW_EARN_ACTIONS="false"
ALLOW_WITHDRAWALS="false"
ALLOW_DEPOSITS_ASSISTANT="true"

# Confirmations
REQUIRE_HUMAN_CONFIRMATION="true"
REQUIRE_2FA_MANUAL_CONFIRMATION="true"
CONFIRMATION_PHRASE="JE COMPRENDS LE RISQUE ET JE VALIDE CETTE ACTION"
KILL_SWITCH="false"

# ==================================================
# Binance — serveur uniquement
# ==================================================
# Créer une clé API sans permission retrait.
# Activer idéalement whitelist IP côté Binance.
BINANCE_BASE_URL="https://api.binance.com"
BINANCE_API_KEY=""
BINANCE_API_SECRET=""
BINANCE_TEST_ORDER_FIRST="true"
BINANCE_ALLOWED_SYMBOLS="BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT"

# Futures / margin restent désactivés par défaut.
BINANCE_FUTURES_BASE_URL="https://fapi.binance.com"
BINANCE_MARGIN_ENABLED="false"
BINANCE_FUTURES_ENABLED="false"
BINANCE_EARN_ENABLED="false"

# ==================================================
# Risk limits
# ==================================================
MAX_TRADE_USDT="10"
MAX_DAILY_LOSS_USDT="3"
MAX_OPEN_TRADES="1"
MAX_LEVERAGE="1"
STOP_LOSS_PERCENT="2"
TAKE_PROFIT_PERCENT="3"
MIN_CONFIDENCE_SCORE="80"
MAX_SPREAD_PERCENT="0.25"
MAX_SLIPPAGE_PERCENT="0.5"
NO_TRADE_IF_VOLATILITY_TOO_HIGH="true"
NO_TRADE_IF_VOLUME_TOO_LOW="true"
NO_TRADE_IF_BALANCE_TOO_LOW="true"

# ==================================================
# External market APIs
# ==================================================
\1\"\"
\1\"\"
\1\"\"
DEXSCREENER_ENABLED="true"

# MEXC optionnel — serveur uniquement
\1\"\"
\1\"\"
MEXC_ENABLED="false"

# ==================================================
# Logs / audit
# ==================================================
AUDIT_LOG_ENABLED="true"
PNL_LOG_ENABLED="true"
RISK_LOG_ENABLED="true"
